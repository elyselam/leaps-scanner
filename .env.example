# Copy to .env and fill in. Do NOT commit .env.

# Discord webhook for #leaps channel (leaps-scanner-leaps)
LEAPS_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Discord webhook for #sell-alerts channel (leaps-scanner-sell-alerts)
SELL_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Discord webhook for #weekly-alerts channel (leaps-scanner-weekly)
WEEKLY_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Discord webhook for #meme channel (leaps-scanner-meme)
# — unusual volume, short squeezes, WSB-trending tickers
MEME_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Polygon API key (free tier). Used for fallback equity bars AND as the
# primary news source for the weekly scanner (/v2/reference/news).
POLYGON_API_KEY=your_polygon_api_key_here

# Finnhub API key — free tier 60 req/min. Used for:
#   - /company-news        : recent headlines (hourly granularity)
#   - /news-sentiment      : pre-computed company sentiment score
# Get one free at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# How far back to pull news for the weekly scanner. Default 48h — short because
# weekly options expire in 4-9 days and react to current flow. Widen to 72-96
# if your universe is illiquid/low-coverage names.
NEWS_HOURS_BACK=48

# Risk-free rate used in Black-Scholes delta / IV calc. Override if you want.
RISK_FREE_RATE=0.045
